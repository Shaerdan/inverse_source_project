  "optimizer_info": {
    "_description": "Information about available optimizers",
    "L-BFGS-B": {
      "type": "local",
      "description": "Local quasi-Newton optimizer with box bounds, uses log barrier for disk constraint",
      "requires": "scipy",
      "recommended_for": "General use, fast convergence when initialized near solution"
    },
    "IPOPT": {
      "type": "local_interior_point", 
      "description": "Interior point optimizer (matches MATLAB fmincon), proper constraint handling",
      "requires": "cyipopt (conda install -c conda-forge cyipopt)",
      "recommended_for": "Best accuracy, MATLAB-equivalent behavior"
    },
    "differential_evolution": {
      "type": "global",
      "description": "Global evolutionary optimizer, slower but explores more of search space",
      "requires": "scipy",
      "recommended_for": "Highly multimodal problems, when local optimizers fail",
      "note": "DEPRECATED - known parameterization issues at domain edges, use L-BFGS-B or IPOPT instead"
    }
  }
}
